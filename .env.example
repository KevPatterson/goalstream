# GoalStream - Variables de Entorno
# Copia este archivo a .env.local y configura tus valores

# ==============================================
# SUPABASE (Base de datos - Opcional)
# ==============================================
# Si planeas usar Supabase para almacenar datos
NEXT_PUBLIC_SUPABASE_URL=tu_url_de_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_clave_anonima_de_supabase

# ==============================================
# APIs de IA (Opcional)
# ==============================================
# Para funcionalidades futuras con IA
OPENAI_API_KEY=tu_clave_de_openai
GEMINI_API_KEY=tu_clave_de_gemini
ANTHROPIC_API_KEY=tu_clave_de_anthropic
PERPLEXITY_API_KEY=tu_clave_de_perplexity

# ==============================================
# ANALYTICS (Opcional)
# ==============================================
# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# ==============================================
# PAGOS (Opcional)
# ==============================================
# Stripe para suscripciones
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXX

# ==============================================
# CONFIGURACIÓN DE DESARROLLO
# ==============================================
# Puerto del servidor de desarrollo (por defecto: 4028)
PORT=4028

# Entorno de ejecución
NODE_ENV=development

# ==============================================
# NOTAS
# ==============================================
# - No compartas este archivo con valores reales en repositorios públicos
# - Usa .env.local para desarrollo local (ignorado por git)
# - Usa variables de entorno del hosting para producción
# - Todas las variables que empiezan con NEXT_PUBLIC_ son accesibles en el cliente
